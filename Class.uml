@startuml
class Conversation {
  id: int
  title : string
  favorite_ia: string
  create_at : timestamp
  update_at : timestamp
}


class Message {
  id: int
  image : array
  create_at : timestamp
  update_at : timestamp
}

class Image {
  id: int
  url: url
  is_main: boolean
  display_order: int
}

class Users {
  id: int
  name: string
}



